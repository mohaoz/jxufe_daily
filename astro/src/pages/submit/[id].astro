---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { difficultyClass, difficultyLabel, getSiteData } from '../../lib/content';
import { withBase } from '../../lib/urls';
import {
  getSubmissionIssueBody,
  getSubmissionIssueTitle,
  getSubmissionIssueUrl,
  siteConfig
} from '../../site.config';

export function getStaticPaths() {
  return getSiteData().problems.map((problem) => ({
    params: { id: problem.id }
  }));
}

const problem = getSiteData().problems.find((item) => item.id === Astro.params.id);

if (!problem) {
  throw new Error(`Unknown problem: ${Astro.params.id}`);
}

const issueUrl = getSubmissionIssueUrl(problem);
const issueTitle = getSubmissionIssueTitle(problem);
const issueBody = getSubmissionIssueBody(problem);
---

<BaseLayout title={`提交做题记录 / ${problem.title}`}>
  <section class="page-heading">
    <div>
      <p class="eyebrow">Submit / <code>{problem.id}</code></p>
      <h1>提交做题记录</h1>
    </div>
    <div class="action-row">
      {issueUrl && <a class="button-link primary" href={issueUrl}>打开 GitHub Issue</a>}
      {problem.submit && <a class="button-link primary" href={problem.submit}>评测入口</a>}
      <a class="button-link secondary" href={withBase(`/problems/${problem.id}/`)}>返回题目</a>
    </div>
  </section>

  <section class="meta-line">
    <span class:list={['difficulty', difficultyClass(problem.difficulty)]}>
      {difficultyLabel(problem.difficulty)}
    </span>
    {problem.tags.map((tag) => <span class="tag">{tag}</span>)}
  </section>

  <section class="panel submit-panel">
    <div class="section-title">
      <h2>Issue 标题模板</h2>
    </div>
    <code class="copy-line">{issueTitle}</code>
  </section>

  <section class="panel submit-panel">
    <div class="section-title">
      <h2>Issue 内容模板</h2>
      {
        siteConfig.github.repository ? (
          <span>使用 issue 模板提交后由仓库自动化处理</span>
        ) : (
          <span>配置仓库后可直接打开 GitHub issue</span>
        )
      }
    </div>
    <textarea class="submission-template" readonly>{issueBody}</textarea>
  </section>
</BaseLayout>
