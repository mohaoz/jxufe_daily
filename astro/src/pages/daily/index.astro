---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSiteData } from '../../lib/content';
import { withBase } from '../../lib/urls';

const data = getSiteData();
const entries = [...data.dailyEntries].reverse();
---

<BaseLayout title="每日训练">
  <section class="page-heading">
    <div>
      <p class="eyebrow">Daily</p>
      <h1>每日训练</h1>
    </div>
  </section>

  <section class="panel">
    <div class="list">
      {
        entries.map((entry) => {
          const submissions = data.submissions.filter((submission) => submission.date === entry.date);
          const users = new Set(submissions.map((submission) => submission.user));
          return (
            <a class="list-row" href={withBase(`/daily/${entry.date}/`)}>
              <span>{entry.date}</span>
              <small>{entry.problems.length} 题 / {users.size} 人 / {submissions.length} 次提交</small>
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
